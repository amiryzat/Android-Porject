<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SELECT AMOUNT"
        android:textSize="11sp"
        android:textColor="@color/campusgo_text_secondary"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:selectionRequired="false"
        android:layout_marginBottom="4dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip10"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RM 10" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip20"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RM 20" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip50"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RM 50" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip100"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RM 100" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipCustom"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Custom" />

    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutCustomAmount"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter amount (RM)"
        android:visibility="gone"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCustomAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PAYMENT METHOD"
        android:textSize="11sp"
        android:textColor="@color/campusgo_text_secondary"
        android:letterSpacing="0.08"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp" />

    <RadioGroup
        android:id="@+id/rgPaymentMethod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <RadioButton
            android:id="@+id/rbOnlineBanking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Online Banking"
            android:textColor="@color/campusgo_text_primary"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbDebitCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Debit Card"
            android:textColor="@color/campusgo_text_primary" />

        <RadioButton
            android:id="@+id/rbBankTransfer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bank Transfer"
            android:textColor="@color/campusgo_text_primary" />

    </RadioGroup>

</LinearLayout>
