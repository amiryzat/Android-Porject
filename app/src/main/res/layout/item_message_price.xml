<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="4dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPrice"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/campusgo_divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvPriceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:textColor="@color/campusgo_text_secondary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvPriceAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/campusgo_text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvPriceNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/campusgo_text_secondary"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPriceStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tag" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAcceptPrice"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Accept"
                    android:textSize="11sp"
                    android:paddingHorizontal="12dp"
                    android:layout_marginStart="8dp"
                    app:backgroundTint="@color/campusgo_success"
                    app:cornerRadius="8dp"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="10sp"
        android:textColor="@color/campusgo_text_hint" />

</LinearLayout>
