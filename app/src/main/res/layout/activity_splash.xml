<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/campusgo_background"
    android:orientation="vertical">

    <!-- Top spacer (pushes content to ~40% mark) -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2" />

    <!-- Logo + name centered -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/logoCard"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/ic_logo_512"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/app_tagline"
            android:textColor="@color/campusgo_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Bottom spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3" />

    <!-- Loading indicator -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        app:indicatorColor="@color/campusgo_primary"
        app:indicatorSize="32dp"
        app:trackThickness="3dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="48dp" />

</LinearLayout>
