<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/campusgo_background">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical"
        android:background="@color/campusgo_background">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            app:tint="@color/campusgo_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Post a Task"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/campusgo_text_primary" />

        <TextView
            android:id="@+id/tvDraft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="NEW"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/campusgo_primary"
            android:letterSpacing="0.06" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/campusgo_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/campusgo_surface"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1: Task Category & Title -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/campusgo_divider"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SELECT CATEGORY"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textColor="@color/campusgo_text_secondary"
                        android:layout_marginBottom="10dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:theme="@style/ThemeOverlay.CampusGO.FilterChipGroup"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipFood"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Food 🍔"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPrint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Print 🖨️" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipParcel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Parcel 📦" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipErrand"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Errand 🏃‍♂️" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipOther"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Other ✨" />

                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TASK TITLE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textColor="@color/campusgo_text_secondary"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutTitle"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxStrokeColor="@color/campusgo_primary"
                        app:boxStrokeWidth="1dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. McD breakfast to KK4"
                            android:inputType="textCapSentences"
                            android:textColor="@color/campusgo_text_primary"
                            android:textSize="15sp"
                            android:paddingVertical="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Locations (Route) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/campusgo_divider"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Pickup section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PICKUP LOCATION"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textColor="@color/campusgo_text_secondary"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutPickupArea"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_map"
                        app:endIconTint="@color/campusgo_primary"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPickupArea"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tap to select pickup on map..."
                            android:focusable="false"
                            android:clickable="true"
                            android:textColor="@color/campusgo_text_primary"
                            android:textSize="14sp"
                            android:paddingVertical="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Pickup Presets -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="2dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quick Pick:"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/campusgo_text_hint"
                                android:layout_marginEnd="8dp"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPickupMcD"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="McD 🍔"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPickupLibrary"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Library 📚"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPickupFSKTM"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FSKTM 💻"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPickupStudent"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Student Ctr 🏢"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPickupKK4"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KK4 🏠"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPickupKK8"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KK8 🏠"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPickupKK12"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KK12 🏠"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </HorizontalScrollView>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutPickup"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPickup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Details (e.g. Counter 3, Library Lobby)"
                            android:inputType="textCapSentences"
                            android:textColor="@color/campusgo_text_primary"
                            android:textSize="14sp"
                            android:paddingVertical="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Divider line with Route Icon decoration -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/campusgo_divider" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  DELIVER TO  "
                            android:textSize="10sp"
                            android:textColor="@color/campusgo_text_hint"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/campusgo_divider" />
                    </LinearLayout>

                    <!-- Dropoff section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DROP-OFF LOCATION"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textColor="@color/campusgo_text_secondary"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDropoffArea"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_map"
                        app:endIconTint="@color/campusgo_primary"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDropoffArea"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tap to select drop-off on map..."
                            android:focusable="false"
                            android:clickable="true"
                            android:textColor="@color/campusgo_text_primary"
                            android:textSize="14sp"
                            android:paddingVertical="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Dropoff Presets -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingVertical="2dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quick Pick:"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/campusgo_text_hint"
                                android:layout_marginEnd="8dp"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipDropoffKK4"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KK4 🏠"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipDropoffKK8"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KK8 🏠"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipDropoffKK12"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KK12 🏠"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipDropoffLibrary"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Library 📚"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipDropoffFSKTM"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FSKTM 💻"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipDropoffStudent"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Student Ctr 🏢"
                                android:textSize="12sp"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipDropoffMcD"
                                style="@style/Widget.Material3.Chip.Suggestion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="McD 🍔"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </HorizontalScrollView>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDropoff"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDropoff"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Details (e.g. Room 312, Block B lobby)"
                            android:inputType="textCapSentences"
                            android:textColor="@color/campusgo_text_primary"
                            android:textSize="14sp"
                            android:paddingVertical="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 3: Details & Budget -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/campusgo_divider"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESCRIPTION / NOTES"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textColor="@color/campusgo_text_secondary"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDescription"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Add details, special instructions (optional)..."
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="2"
                            android:gravity="top"
                            android:textColor="@color/campusgo_text_primary"
                            android:textSize="14sp"
                            android:paddingVertical="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Price Input Card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_price_card"
                        android:padding="16dp"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OFFERED PAYMENT"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:textColor="@color/campusgo_text_secondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RM "
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/campusgo_text_primary" />

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPrice"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@android:color/transparent"
                                android:hint="0.00"
                                android:inputType="numberDecimal"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/campusgo_text_primary"
                                android:padding="0dp" />
                        </LinearLayout>

                        <!-- Price quick adjusters -->
                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:layout_marginTop="12dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipPriceRM5"
                                    style="@style/Widget.Material3.Chip.Suggestion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RM 5"
                                    android:textSize="12sp"
                                    android:layout_marginEnd="6dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipPriceRM8"
                                    style="@style/Widget.Material3.Chip.Suggestion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RM 8"
                                    android:textSize="12sp"
                                    android:layout_marginEnd="6dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipPriceRM12"
                                    style="@style/Widget.Material3.Chip.Suggestion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RM 12"
                                    android:textSize="12sp"
                                    android:layout_marginEnd="6dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipPriceRM15"
                                    style="@style/Widget.Material3.Chip.Suggestion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RM 15"
                                    android:textSize="12sp"
                                    android:layout_marginEnd="12dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipPricePlus2"
                                    style="@style/Widget.Material3.Chip.Suggestion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+ RM 2"
                                    android:textSize="12sp"
                                    android:layout_marginEnd="6dp"
                                    app:chipStrokeColor="@color/campusgo_primary" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipPricePlus5"
                                    style="@style/Widget.Material3.Chip.Suggestion"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+ RM 5"
                                    android:textSize="12sp"
                                    app:chipStrokeColor="@color/campusgo_primary" />
                            </LinearLayout>
                        </HorizontalScrollView>
                    </LinearLayout>

                    <!-- Toggle buttons in horizontal orientation -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNegotiable"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="NEGOTIABLE"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="4dp"
                            app:strokeColor="@color/campusgo_divider"
                            app:cornerRadius="22dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEmergency"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="!! EMERGENCY"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginStart="4dp"
                            app:strokeColor="@color/campusgo_divider"
                            app:cornerRadius="22dp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Post button footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:background="@color/campusgo_background">

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/campusgo_divider"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPost"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Post to Feed"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/campusgo_primary"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>
