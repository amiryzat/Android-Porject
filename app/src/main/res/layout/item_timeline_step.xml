<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <!-- Dot + line column -->
    <LinearLayout
        android:layout_width="24dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvStepDot"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@color/campusgo_text_secondary" />

        <View
            android:id="@+id/vStepLine"
            android:layout_width="2dp"
            android:layout_height="28dp"
            android:background="@color/campusgo_divider" />
    </LinearLayout>

    <!-- Step info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/campusgo_text_secondary" />

        <TextView
            android:id="@+id/tvStepTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/campusgo_text_hint" />
    </LinearLayout>

</LinearLayout>
