<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/campusgo_background">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        android:background="@color/campusgo_background">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Confirm Acceptance"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/campusgo_text_primary" />

        <View android:layout_width="48dp" android:layout_height="48dp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/campusgo_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Handshake icon circle -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤝"
                    android:textSize="36sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lock this task in?"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/campusgo_text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Once accepted, both sides commit to the agreed price."
                android:textSize="14sp"
                android:textColor="@color/campusgo_text_secondary"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Task summary card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/campusgo_background"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/campusgo_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Task" android:textSize="13sp" android:textColor="@color/campusgo_text_secondary" />
                        <TextView android:id="@+id/tvTaskTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/campusgo_text_primary" android:maxWidth="200dp" android:ellipsize="end" android:maxLines="1" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Posted by" android:textSize="13sp" android:textColor="@color/campusgo_text_secondary" />
                        <TextView android:id="@+id/tvPostedBy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/campusgo_text_primary" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Price card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_price_card"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Original offer" android:textSize="13sp" android:textColor="@color/campusgo_text_secondary" />
                    <TextView android:id="@+id/tvOriginalPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="@color/campusgo_text_secondary" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Final agreed price" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/campusgo_text_primary" />
                        <TextView android:id="@+id/tvPriceSource" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="@color/campusgo_text_secondary" />
                    </LinearLayout>
                    <TextView android:id="@+id/tvFinalPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="28sp" android:textStyle="bold" android:textColor="@color/campusgo_text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- T&C note -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/campusgo_divider"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="By accepting you agree to follow the campus community rules. No-shows and cancellations affect your rating."
                    android:textSize="12sp"
                    android:textColor="@color/campusgo_text_secondary"
                    android:lineSpacingMultiplier="1.4" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/campusgo_background">

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/campusgo_divider" android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Confirm &amp; Accept"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            app:backgroundTint="@color/campusgo_text_primary"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToNeg"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Back to negotiation"
            android:textSize="15sp"
            app:strokeColor="@color/campusgo_divider"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>
