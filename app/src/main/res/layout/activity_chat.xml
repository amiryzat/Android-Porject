<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/campusgo_background">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbarContainer"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        android:background="@color/campusgo_background">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/tvOtherName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/campusgo_text_primary" />

            <TextView
                android:id="@+id/tvTaskRef"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/campusgo_text_secondary" />
        </LinearLayout>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/campusgo_divider" />

    <!-- Agreed price banner (visible when price agreed) -->
    <LinearLayout
        android:id="@+id/llAgreedBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/campusgo_primary_light"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvAgreedPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="@color/campusgo_primary_dark"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmNow"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Confirm"
            android:textSize="12sp"
            android:paddingHorizontal="14dp"
            app:backgroundTint="@color/campusgo_primary"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="8dp" />

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/campusgo_background">

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/campusgo_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPriceOffer"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="$"
                android:textSize="16sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/campusgo_divider"
                app:cornerRadius="22dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:boxStrokeColor="@color/campusgo_divider"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="22dp"
                app:boxCornerRadiusTopEnd="22dp"
                app:boxCornerRadiusBottomStart="22dp"
                app:boxCornerRadiusBottomEnd="22dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Type a message..."
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="4"
                    android:textSize="14sp"
                    android:textColor="@color/campusgo_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSend"
                style="@style/Widget.Material3.Button"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="→"
                android:textSize="16sp"
                android:padding="0dp"
                app:backgroundTint="@color/campusgo_text_primary"
                app:cornerRadius="22dp" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
